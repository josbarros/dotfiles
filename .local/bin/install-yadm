#!/bin/sh

# Add yadm repo before upgrading
if [ -d /etc/dnf/ ]; then
    sudo dnf config-manager addrepo --from-repofile=https://download.opensuse.org/repositories/home:TheLocehiliosan:yadm/Fedora_42/home:TheLocehiliosan:yadm.repo 2> /dev/null
    dnf check-update 2> /dev/null
    sudo dnf install -y yadm 2> /dev/null
elif [ -d /etc/apt/ ]; then
    sudo apt update > /dev/null 2>&1
    sudo apt install -y yadm > /dev/null 2>&1
else
    echo "No supported package manager found" >&2
    exit 1
fi

if ! command -v yadm > /dev/null 2>&1; then
    echo "yadm installation failed" >&2
    exit 1
fi

# Add ssh keys
SSH_DIR="$HOME/.ssh"
mkdir -p "$SSH_DIR"
cd "$SSH_DIR" 
while true; do
    if ssh-add -L > /dev/null 2>&1; then
        echo "SSH key(s) are loaded!"
        break
    fi
    echo "Waiting for the user to get an SSH key from an external hardware key"
    ssh-keygen -K
done
cd - > /dev/null

# Clone the dotfiles repo
export GIT_SSH_COMMAND="ssh -o IdentityAgent=none -o IdentitiesOnly=yes -i $SSH_DIR/id_ed25519_sk_rk"
yadm clone git@github.com:josbarros/dotfiles.git 2> /dev/null || {
    echo "yadm clone failed" >&2
    exit 1
}

yadm gitconfig user.email "joserui@joseruibarros.com" || {
    echo "failed to set yadm git user.email" >&2
    exit 1
}

yadm gitconfig user.name "José Rui Barros" || {
    echo "failed to set yadm git user.name" >&2
    exit 1
}

# Finish off
rm -rf ~/.gnupg
echo "Succssess! Please log off now to refresh .profile"
