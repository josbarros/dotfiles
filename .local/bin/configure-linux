#!/bin/sh

# Begin
pkg-update

# Set base dirs to english 
rm -f "$XDG_CONFIG_HOME/user-dirs.dirs"
LANG=en_US.UTF-8 xdg-user-dirs-update 
echo 'pt_PT' > "$XDG_CONFIG_HOME/user-dirs.locale" # Avoid annoying popup at boot

# Install tlp
sudo "$PCKMNG" install -y tlp tlp-rdw
sudo "$PCKMNG" remove -y tuned tuned-ppd

if ps -p 1 | grep -q "systemd"; then
	sudo systemctl enable tlp.service
	sudo systemctl mask systemd-rfkill.service systemd-rfkill.socket
fi

# Install powertop
sudo "$PCKMNG" install -y powertop
# TODO Ver maneira de ja esta calibrado ou nao, ou se isso e' sequer preciso
# sudo powertop -c # calibrate

# Install gnome tools + pipx
sudo "$PCKMNG" install -y gnome-tweaks gnome-extensions-app pipx

# Install gnome extensions - marcs14 is the power manager
pipx install gnome-extensions-cli
gext install accent-directories@taiwbi.com appindicatorsupport@rgcjonas.gmail.com auto-accent-colour@Wartybix drive-menu@gnome-shell-extensions.gcampax.github.com marcs14@gmail.com power-switching-manager@joseruibarros.com

# Configure gnome settings

# Move window buttons to the left, like MacOS
gsettings set org.gnome.desktop.wm.preferences button-layout "close:appmenu"

# Swap esc and caps, right ctrl as compose key - this resets all other keyboard settings, careful!
gsettings set org.gnome.desktop.input-sources xkb-options "['caps:swapescape','compose:rctrl']"

# Set location and night light
gsettings set org.gnome.system.location enabled true
gsettings set org.gnome.settings-daemon.plugins.color night-light-enabled true
gsettings set org.gnome.settings-daemon.plugins.color night-light-schedule-automatic true

# Set automatic date time and time zone
# TODO add automatic date and time
gsettings set org.gnome.desktop.datetime automatic-timezone true

# Show battery percentage
gsettings set org.gnome.desktop.interface show-battery-percentage true
