prefix_rule(pattern=["bru", "--help"], decision="allow")
prefix_rule(pattern=["bru", "--version"], decision="allow")
prefix_rule(pattern=["bru", "run", "--help"], decision="allow")
prefix_rule(pattern=["bruno", "--version"], decision="allow")
prefix_rule(pattern=["docker", "--version"], decision="allow")
prefix_rule(pattern=["docker", "compose", "version"], decision="allow")
prefix_rule(pattern=["git", "ls-files"], decision="allow")
prefix_rule(pattern=["gradle", "-v"], decision="allow")
prefix_rule(pattern=["gradle", "test"], decision="allow")
prefix_rule(pattern=["java", "-version"], decision="allow")
prefix_rule(pattern=["node", "--version"], decision="allow")
prefix_rule(pattern=["npm", "--version"], decision="allow")
prefix_rule(pattern=["sort"], decision="allow")
